@{
    ViewData["Title"] = "Dashboard";
    ViewData["IsAuthenticated"] = Model?.IsAuthenticated ?? false;
    ViewData["Username"] = Model?.Username ?? "Guest";
}

<div class="card">
    <h1 class="card-title">📊 Sync Dashboard</h1>
    
    @if (Model?.IsAuthenticated == true)
    {
        <div class="alert alert-success">
            ✅ Connected to MyAnimeList as <strong>@Model.Username</strong>
        </div>
        
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-value">@(Model.TotalAnime ?? 0)</div>
                <div class="stat-label">Total Anime in Library</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">@(Model.SyncedAnime ?? 0)</div>
                <div class="stat-label">Synced with MAL</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">@(Model.LastSyncTime ?? "Never")</div>
                <div class="stat-label">Last Sync</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">@(Model.PendingUpdates ?? 0)</div>
                <div class="stat-label">Pending Updates</div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-warning">
            ⚠️ Not connected to MyAnimeList. Please log in to start syncing.
        </div>
        
        <p style="margin-top: 2rem; color: #4a5568;">
            Connect your MyAnimeList account to automatically sync your watch history from Shoko Server.
        </p>
        
        <div style="margin-top: 2rem;">
            <a href="/anisync/login" class="btn btn-primary">Login with MyAnimeList</a>
        </div>
    }
</div>

@if (Model?.IsAuthenticated == true)
{
    <div class="card">
        <h2 class="card-title">🔄 Recent Sync Activity</h2>
        
        @if (Model.RecentActivity?.Any() == true)
        {
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="border-bottom: 2px solid #e2e8f0;">
                        <th style="padding: 1rem; text-align: left; color: #4a5568;">Time</th>
                        <th style="padding: 1rem; text-align: left; color: #4a5568;">Anime</th>
                        <th style="padding: 1rem; text-align: left; color: #4a5568;">Episode</th>
                        <th style="padding: 1rem; text-align: left; color: #4a5568;">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var activity in Model.RecentActivity)
                    {
                        <tr style="border-bottom: 1px solid #e2e8f0;">
                            <td style="padding: 1rem; color: #718096;">@activity.Time</td>
                            <td style="padding: 1rem; color: #2d3748;">@activity.AnimeName</td>
                            <td style="padding: 1rem; color: #718096;">Episode @activity.Episode</td>
                            <td style="padding: 1rem;">
                                @if (activity.Success)
                                {
                                    <span style="color: #48bb78;">✓ Synced</span>
                                }
                                else
                                {
                                    <span style="color: #f56565;">✗ Failed</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p style="color: #718096;">No recent sync activity</p>
        }
    </div>
}