@{
    ViewData["Title"] = "Login";
    ViewData["IsAuthenticated"] = false;
}

<div class="card" style="max-width: 500px; margin: 4rem auto;">
    <h1 class="card-title" style="text-align: center;">🔐 Connect to MyAnimeList</h1>
    
    <div style="text-align: center; margin: 2rem 0;">
        <img src="https://cdn.myanimelist.net/images/mal-logo-large.png" alt="MyAnimeList" style="height: 60px; opacity: 0.8;">
    </div>
    
    <p style="text-align: center; color: #718096; margin-bottom: 2rem;">
        Authorize Shoko AniSync to access your MyAnimeList account and automatically sync your anime watch history.
    </p>
    
    <div style="background: #f7fafc; border-radius: 0.5rem; padding: 1.5rem; margin-bottom: 2rem;">
        <h3 style="color: #2d3748; margin-bottom: 1rem;">What this plugin will do:</h3>
        <ul style="color: #4a5568; list-style: none; padding: 0;">
            <li style="margin-bottom: 0.5rem;">✓ Read your anime list</li>
            <li style="margin-bottom: 0.5rem;">✓ Update episode progress when you watch in Shoko</li>
            <li style="margin-bottom: 0.5rem;">✓ Mark anime as completed when you finish a series</li>
            <li style="margin-bottom: 0.5rem;">✓ Sync your watch history automatically</li>
        </ul>
    </div>
    
    <div style="background: #fef5e7; border: 1px solid #fbd38d; border-radius: 0.5rem; padding: 1rem; margin-bottom: 2rem;">
        <strong style="color: #7c2d12;">Note:</strong>
        <span style="color: #975a16;">You will be redirected to MyAnimeList to authorize access. After authorization, you'll be redirected back here.</span>
    </div>
    
    <form action="/anisync/auth" method="get">
        <button type="submit" class="btn btn-primary" style="width: 100%; padding: 1rem; font-size: 1.1rem;">
            Connect with MyAnimeList >
        </button>
    </form>
    
    <p style="text-align: center; color: #a0aec0; font-size: 0.9rem; margin-top: 2rem;">
        By connecting, you agree to allow Shoko AniSync to manage your anime list.
        You can revoke access anytime from your MAL settings.
    </p>
</div>