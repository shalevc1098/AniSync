<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Shoko MAL Sync</title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #0a0e27;
            background-image: linear-gradient(180deg, #0a0e27 0%, #1a1d3a 100%);
            min-height: 100vh;
            color: #e1e7f5;
            margin: 0;
            padding: 20px;
        }
        .container {
            max-width: 1200px;
            margin: 0 auto;
        }
        .card {
            background: #1c2137;
            border-radius: 8px;
            padding: 2rem;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
            border: 1px solid #2b3556;
            margin-bottom: 2rem;
        }
        h1 {
            color: #46bcf2;
        }
        a {
            color: #46bcf2;
            text-decoration: none;
        }
        a:hover {
            color: #5cc9f5;
        }
        .nav {
            margin-bottom: 2rem;
            padding: 1rem;
            background: #2e51a2;
            border-radius: 8px;
        }
        .nav a {
            margin-right: 1rem;
            color: #e1e7f5;
        }
        .nav a:hover {
            color: #46bcf2;
        }
        ul {
            list-style: none;
            padding: 0;
        }
        li {
            padding: 0.5rem 0;
            border-bottom: 1px solid #2b3556;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="nav">
            <a href="/razor">Home</a>
            <a href="/razor/test">Test</a>
            <a href="/razor/config">Config</a>
            <a href="/anisync">Back to AniSync</a>
        </div>
        
        <div class="card">
            @RenderBody()
        </div>
    </div>
</body>
</html>