@model Shoko.AniSync.Configuration.Config
@{
    Layout = "_Layout";
    ViewData["Title"] = "Configuration";
}

<h1>Current Configuration</h1>

@if(Model != null)
{
    <div style="margin-top: 2rem;">
        <h2>Authentication Status</h2>
        @if(Model.UserApiAuth != null)
        {
            <p style="color: #22c55e;">✓ Authenticated as: @Model.UserApiAuth.Username</p>
            <p>Provider: @Model.UserApiAuth.Name</p>
        }
        else
        {
            <p style="color: #ef4444;">✗ Not authenticated</p>
        }
    </div>

    <div style="margin-top: 2rem;">
        <h2>Sync Settings</h2>
        <table style="width: 100%; border-collapse: collapse;">
            <tr>
                <td style="padding: 0.5rem; border: 1px solid #2b3556;">Auto Sync:</td>
                <td style="padding: 0.5rem; border: 1px solid #2b3556;">
                    @if(Model.EnableAutoSync)
                    {
                        <span style="color: #22c55e;">✓ Enabled</span>
                    }
                    else
                    {
                        <span style="color: #ef4444;">✗ Disabled</span>
                    }
                </td>
            </tr>
            <tr>
                <td style="padding: 0.5rem; border: 1px solid #2b3556;">Sync Only Completed:</td>
                <td style="padding: 0.5rem; border: 1px solid #2b3556;">@Model.SyncOnlyCompleted</td>
            </tr>
            <tr>
                <td style="padding: 0.5rem; border: 1px solid #2b3556;">Rewatch Detection:</td>
                <td style="padding: 0.5rem; border: 1px solid #2b3556;">@Model.EnableRewatchDetection</td>
            </tr>
            <tr>
                <td style="padding: 0.5rem; border: 1px solid #2b3556;">Allow Rollback:</td>
                <td style="padding: 0.5rem; border: 1px solid #2b3556;">@Model.AllowRollback</td>
            </tr>
            <tr>
                <td style="padding: 0.5rem; border: 1px solid #2b3556;">Title Match Threshold:</td>
                <td style="padding: 0.5rem; border: 1px solid #2b3556;">@Model.TitleMatchThreshold</td>
            </tr>
            <tr>
                <td style="padding: 0.5rem; border: 1px solid #2b3556;">Sync Delay (seconds):</td>
                <td style="padding: 0.5rem; border: 1px solid #2b3556;">@Model.SyncDelaySeconds</td>
            </tr>
        </table>
    </div>
}
else
{
    <p>No configuration found.</p>
}