@{
    ViewData["Title"] = "Sync History";
    ViewData["IsAuthenticated"] = Model?.IsAuthenticated ?? false;
    ViewData["Username"] = Model?.Username ?? "Guest";
}

<div class="card">
    <h1 class="card-title">📜 Sync History</h1>
    
    <div style="display: flex; gap: 1rem; margin-bottom: 2rem;">
        <button class="btn btn-secondary" onclick="filterHistory('all')">All</button>
        <button class="btn btn-secondary" onclick="filterHistory('success')">✓ Successful</button>
        <button class="btn btn-secondary" onclick="filterHistory('failed')">✗ Failed</button>
        <button class="btn btn-secondary" onclick="filterHistory('today')">Today</button>
        <button class="btn btn-secondary" onclick="filterHistory('week')">This Week</button>
    </div>
    
    @if (Model?.SyncHistory?.Any() == true)
    {
        <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: #f7fafc; border-bottom: 2px solid #e2e8f0;">
                        <th style="padding: 1rem; text-align: left; color: #4a5568;">Date/Time</th>
                        <th style="padding: 1rem; text-align: left; color: #4a5568;">Anime</th>
                        <th style="padding: 1rem; text-align: left; color: #4a5568;">Episode</th>
                        <th style="padding: 1rem; text-align: left; color: #4a5568;">Action</th>
                        <th style="padding: 1rem; text-align: left; color: #4a5568;">Status</th>
                        <th style="padding: 1rem; text-align: left; color: #4a5568;">Details</th>
                    </tr>
                </thead>
                <tbody id="history-table">
                    @foreach (var entry in Model.SyncHistory)
                    {
                        <tr class="history-row" data-status="@(entry.Success ? "success" : "failed")" data-date="@entry.Timestamp.ToString("yyyy-MM-dd")">
                            <td style="padding: 1rem; color: #718096;">@entry.Timestamp.ToString("MMM dd, HH:mm")</td>
                            <td style="padding: 1rem; color: #2d3748; font-weight: 500;">@entry.AnimeName</td>
                            <td style="padding: 1rem; color: #718096;">Episode @entry.Episode</td>
                            <td style="padding: 1rem;">
                                @switch(entry.Action)
                                {
                                    case "watched":
                                        <span style="color: #48bb78;">👁️ Watched</span>
                                        break;
                                    case "unwatched":
                                        <span style="color: #a0aec0;">👁️‍🗨️ Unwatched</span>
                                        break;
                                    case "completed":
                                        <span style="color: #805ad5;">✅ Completed</span>
                                        break;
                                    case "rewatch":
                                        <span style="color: #3182ce;">🔄 Rewatch</span>
                                        break;
                                    default:
                                        <span>@entry.Action</span>
                                        break;
                                }
                            </td>
                            <td style="padding: 1rem;">
                                @if (entry.Success)
                                {
                                    <span style="color: #48bb78; font-weight: 500;">✓ Success</span>
                                }
                                else
                                {
                                    <span style="color: #f56565; font-weight: 500;">✗ Failed</span>
                                }
                            </td>
                            <td style="padding: 1rem; color: #718096; font-size: 0.9rem;">
                                @if (!string.IsNullOrEmpty(entry.ErrorMessage))
                                {
                                    <span style="color: #f56565;">@entry.ErrorMessage</span>
                                }
                                else
                                {
                                    <span>@entry.Details</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        <div style="margin-top: 2rem; text-align: center;">
            <button class="btn btn-secondary" onclick="loadMore()">Load More</button>
        </div>
    }
    else
    {
        <div style="text-align: center; padding: 3rem; color: #718096;">
            <p style="font-size: 1.2rem; margin-bottom: 1rem;">No sync history available</p>
            <p>Start watching anime in Shoko to see your sync history here.</p>
        </div>
    }
</div>

<div class="card">
    <h2 class="card-title">📊 Sync Statistics</h2>
    
    <div class="stats-grid">
        <div style="background: #f0fff4; padding: 1.5rem; border-radius: 0.5rem; border: 1px solid #9ae6b4;">
            <div style="font-size: 2rem; font-weight: bold; color: #276749;">@(Model?.TotalSyncs ?? 0)</div>
            <div style="color: #38a169;">Total Syncs</div>
        </div>
        
        <div style="background: #fed7e7; padding: 1.5rem; border-radius: 0.5rem; border: 1px solid #fc8181;">
            <div style="font-size: 2rem; font-weight: bold; color: #9b2c2c;">@(Model?.FailedSyncs ?? 0)</div>
            <div style="color: #e53e3e;">Failed Syncs</div>
        </div>
        
        <div style="background: #e6fffa; padding: 1.5rem; border-radius: 0.5rem; border: 1px solid #81e6d9;">
            <div style="font-size: 2rem; font-weight: bold; color: #234e52;">@(Model?.SuccessRate ?? "0")%</div>
            <div style="color: #319795;">Success Rate</div>
        </div>
        
        <div style="background: #fef5e7; padding: 1.5rem; border-radius: 0.5rem; border: 1px solid #fbd38d;">
            <div style="font-size: 2rem; font-weight: bold; color: #7c2d12;">@(Model?.LastSync ?? "Never")</div>
            <div style="color: #dd6b20;">Last Sync</div>
        </div>
    </div>
</div>

<script>
function filterHistory(filter) {
    const rows = document.querySelectorAll('.history-row');
    const today = new Date().toISOString().split('T')[0];
    const weekAgo = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString().split('T')[0];
    
    rows.forEach(row => {
        let show = true;
        
        switch(filter) {
            case 'success':
                show = row.dataset.status === 'success';
                break;
            case 'failed':
                show = row.dataset.status === 'failed';
                break;
            case 'today':
                show = row.dataset.date === today;
                break;
            case 'week':
                show = row.dataset.date >= weekAgo;
                break;
        }
        
        row.style.display = show ? '' : 'none';
    });
}

function loadMore() {
    // Implementation for loading more history entries
    console.log('Load more history...');
}
</script>